---
interface Props {
  text: string;
  variant?: 'default' | 'success' | 'warning';
}

const { text, variant = 'default' } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-accent/10 text-accent-light border-accent/20',
  success: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  warning: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
};
---

<span class:list={['inline-flex items-center px-3 py-1 rounded-full text-xs font-label font-medium border', variantClasses[variant]]}>
  {text}
</span>
