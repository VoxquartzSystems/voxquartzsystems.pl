---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Porozmawiajmy o Twoim projekcie',
  description = 'Opisz swoje potrzeby — przeanalizuję je i zaproponuję rozwiązanie dopasowane do Twojego biznesu.'
} = Astro.props;
---

<section class="mt-20 mb-12">
  <div class="relative overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-accent/5 via-bg-card to-bg-card p-8 md:p-12 text-center">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--color-accent-glow),transparent_70%)]"></div>
    <div class="relative">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary mb-4">
        {title}
      </h2>
      <p class="text-text-muted text-lg max-w-2xl mx-auto mb-8">
        {description}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="mailto:kontakt@voxquartzsystems.pl"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-light text-white font-label font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
        >
          Skontaktuj się
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 px-8 py-3.5 border border-border hover:border-border-hover text-text-muted hover:text-text-primary font-label font-semibold rounded-xl transition-all duration-300"
        >
          Zobacz realizacje
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
