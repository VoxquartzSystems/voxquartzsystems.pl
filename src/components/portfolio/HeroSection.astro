<script>
// ===== Typed text effect =====
(function() {
    const phrases = ['Aplikacje mobilne', 'Systemy SaaS', 'Sklepy e-commerce', 'Integracje AI'];
    const typedEl = document.getElementById('typed-text');
    if (!typedEl) return;

    // Check reduced motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
        typedEl.textContent = phrases.join(' \u2022 ');
        return;
    }

    let phraseIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let pauseEnd = 0;

    // Add cursor span
    const cursorSpan = document.createElement('span');
    cursorSpan.className = 'cursor';
    typedEl.parentNode.appendChild(cursorSpan);

    function type() {
        const now = Date.now();
        if (now < pauseEnd) {
            requestAnimationFrame(type);
            return;
        }

        const currentPhrase = phrases[phraseIndex];

        if (!isDeleting) {
            charIndex++;
            typedEl.textContent = currentPhrase.substring(0, charIndex);

            if (charIndex === currentPhrase.length) {
                isDeleting = true;
                pauseEnd = now + 2000;
            }
        } else {
            charIndex--;
            typedEl.textContent = currentPhrase.substring(0, charIndex);

            if (charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
            }
        }

        const speed = isDeleting ? 40 : 80;
        setTimeout(() => requestAnimationFrame(type), speed);
    }

    // Start after page load
    setTimeout(type, 1200);
})();
</script>
