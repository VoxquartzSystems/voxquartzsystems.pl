---
const navLinks = [
  { label: 'Integracje', href: '/integracje/' },
  { label: 'Alternatywy', href: '/alternatywa-dla/' },
  { label: 'AI dla biznesu', href: '/ai-dla/' },
  { label: 'Narzędzia', href: '/narzedzia/' },
  { label: 'Kontakt', href: 'mailto:kontakt@voxquartzsystems.pl' },
];
---

<header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-xl border-b border-border">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-xl font-display font-bold text-text-primary group-hover:text-accent-light transition-colors">
        Voxquartz<span class="text-accent">Systems</span>
      </span>
    </a>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-muted hover:text-text-primary transition-colors"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-label text-text-muted hover:text-text-primary hover:bg-accent/5 rounded-lg transition-all"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-bg/95 backdrop-blur-xl">
    <ul class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block px-3 py-2.5 text-sm font-label text-text-muted hover:text-text-primary hover:bg-accent/5 rounded-lg transition-all"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
