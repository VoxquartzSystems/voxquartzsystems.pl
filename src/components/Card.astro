---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
}

const { title, description, href, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block bg-bg-card border border-border rounded-2xl p-6 transition-all duration-300 hover:bg-bg-card-hover hover:border-border-hover hover:shadow-lg hover:shadow-accent/5"
>
  <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-accent-light transition-colors">
    {title}
  </h3>
  <p class="text-text-muted text-sm leading-relaxed mb-4 line-clamp-3">
    {description}
  </p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded bg-accent/5 text-text-dim border border-border">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
